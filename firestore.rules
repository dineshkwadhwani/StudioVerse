rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentUserType() {
      return isSignedIn() ? currentUser().userType : null;
    }

    function currentUserIdValue() {
      return isSignedIn() ? currentUser().userId : null;
    }

    function currentUserUidValue() {
      return isSignedIn() ? currentUser().uid : null;
    }

    function currentTenantId() {
      return isSignedIn() ? currentUser().tenantId : null;
    }

    function currentCompanyId() {
      return isSignedIn() ? currentUser().associatedCompanyId : null;
    }

    function isSuperAdmin() {
      return isSignedIn() && currentUserType() == "superadmin";
    }

    function isCompanyUser() {
      return isSignedIn() && currentUserType() == "company";
    }

    function isProfessionalUser() {
      return isSignedIn() && currentUserType() == "professional";
    }

    // ── Users ──────────────────────────────────────────────────────────────
    // Login queries users by phoneE164+tenantId so collection reads must be
    // open to any authenticated user. Writes are scoped to own document.
    // Company/professional can also update profiles of users they manage
    // (createScopedManagedUser, saveCohort run from the client and write
    //  managed user docs directly).
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin()
                    || (isSignedIn() && (
                         request.auth.uid == userId ||
                         request.auth.uid == resource.data.uid
                       ))
                    || (isCompanyUser() &&
                         resource.data.associatedCompanyId == currentCompanyId())
                    || (isProfessionalUser() &&
                         resource.data.associatedProfessionalId == request.auth.uid);
      allow delete: if false;
    }

    // ── Tenants ────────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    // ── Wallets ────────────────────────────────────────────────────────────
    // Company users need to update the recipient wallet when approving coin
    // requests (transferCoins updates both fromUserId and toUserId wallets
    // in one transaction from the client).
    match /wallets/{walletId} {
      allow read:   if isSuperAdmin()
                    || (isSignedIn() && (
                         request.auth.uid == walletId ||
                         request.auth.uid == resource.data.userId
                       ));
      allow create: if isSignedIn();
      allow update: if isSuperAdmin()
                    || (isSignedIn() && (
                         request.auth.uid == walletId ||
                         request.auth.uid == resource.data.userId
                       ))
                    || (isCompanyUser() &&
                         get(/databases/$(database)/documents/users/$(resource.data.userId)).data.associatedCompanyId == currentCompanyId());
      allow delete: if false;
    }

    // ── Wallet Transactions ────────────────────────────────────────────────
    match /walletTransactions/{txId} {
      allow read:   if isSuperAdmin()
                    || (isSignedIn() && (
                         resource.data.userId   == request.auth.uid ||
                         resource.data.walletId == request.auth.uid ||
                         resource.data.createdBy == request.auth.uid
                       ));
      allow create: if isSignedIn();
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ── Assessments ────────────────────────────────────────────────────────
    match /assessments/{assessmentId} {
      allow read:  if true;
      allow write: if isSuperAdmin() || isSignedIn();
    }

    // ── Assessment Questions ───────────────────────────────────────────────
    match /assessmentQuestions/{questionId} {
      allow read:   if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Assessment Attempts ────────────────────────────────────────────────
    match /assessmentAttempts/{attemptId} {
      allow read:   if isSuperAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    // ── Assessment Reports ─────────────────────────────────────────────────
    match /assessmentReports/{reportId} {
      allow read:   if isSuperAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ── Programs ──────────────────────────────────────────────────────────
    match /programs/{programId} {
      allow read:  if true;
      allow write: if isSuperAdmin() || isSignedIn();
    }

    // ── Events ────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read:  if true;
      allow write: if isSuperAdmin() || isSignedIn();
    }

    // ── Assignments ────────────────────────────────────────────────────────
    match /assignments/{assignmentId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin()
                    || (isSignedIn() && (
                         resource.data.assignedTo  == request.auth.uid ||
                         resource.data.assignedBy  == request.auth.uid ||
                         resource.data.assignerId  == request.auth.uid ||
                         resource.data.assigneeId  == request.auth.uid
                       ));
      allow delete: if false;
    }

    // ── Cohorts ────────────────────────────────────────────────────────────
    match /cohorts/{cohortId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || isSignedIn();
      allow delete: if isSuperAdmin();
    }

    // ── Cohort Members ─────────────────────────────────────────────────────
    // saveCohort deletes and re-creates members from the client so the cohort
    // owner (company or professional) needs delete permission on their own cohort.
    match /cohortMembers/{memberId} {
      allow read:   if isSignedIn();
      allow create: if isSuperAdmin() || isCompanyUser() || isProfessionalUser();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin()
                    || (isCompanyUser() && resource.data.companyId == currentCompanyId())
                    || (isProfessionalUser() && resource.data.professionalId == request.auth.uid);
    }

    // ── Cohort Assignments ─────────────────────────────────────────────────
    match /cohortAssignments/{cohortAssignmentId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || isSignedIn();
      allow delete: if isSuperAdmin();
    }

    // ── Referrals ──────────────────────────────────────────────────────────
    match /referrals/{referralId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    // ── Coin Requests ──────────────────────────────────────────────────────
    match /coinRequests/{requestId} {
      allow create: if isProfessionalUser()
        && request.resource.data.requesterProfessionalId == request.auth.uid
        && request.resource.data.tenantId == currentTenantId()
        && request.resource.data.companyId == currentCompanyId()
        && request.resource.data.status == "pending"
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;

      allow read: if isSuperAdmin()
        || (isSignedIn() && (
              resource.data.requesterProfessionalId == request.auth.uid
              || resource.data.companyId == request.auth.uid
              || resource.data.companyId == currentUserIdValue()
              || resource.data.companyId == currentUserUidValue()
              || (isCompanyUser() && resource.data.companyId == currentCompanyId())
           ));

      allow update: if isSuperAdmin()
        || ((
              resource.data.companyId == request.auth.uid
              || resource.data.companyId == currentUserIdValue()
              || resource.data.companyId == currentUserUidValue()
              || (isCompanyUser() && resource.data.companyId == currentCompanyId())
            )
            && resource.data.status == "pending"
            && request.resource.data.status in ["approved", "denied"]
            && request.resource.data.requesterProfessionalId == resource.data.requesterProfessionalId
            && request.resource.data.companyId == resource.data.companyId
            && request.resource.data.tenantId == resource.data.tenantId
            && request.resource.data.amount == resource.data.amount);

      allow delete: if false;
    }

    // ── Coin Packages ──────────────────────────────────────────────────────
    match /coinPackages/{packageId} {
      allow read:   if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Coin Orders ────────────────────────────────────────────────────────
    match /coinOrders/{orderId} {
      allow read:   if isSuperAdmin()
                    || (isSignedIn() && (
                         resource.data.userId    == request.auth.uid ||
                         resource.data.createdBy == request.auth.uid
                       ));
      allow create: if isSignedIn();
      allow update: if isSuperAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if false;
    }

    // ── Promotion Packages ─────────────────────────────────────────────────
    match /promotionPackages/{packageId} {
      allow read:   if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Program Promotion Requests ─────────────────────────────────────────
    match /programPromotionRequests/{requestId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || isSignedIn();
      allow delete: if isSuperAdmin();
    }

    // ── Bot Knowledge ──────────────────────────────────────────────────────
    match /bot-knowledge/{docId} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    // ── Audit Logs ─────────────────────────────────────────────────────────
    // Written by Firebase Functions (admin SDK, bypasses rules).
    // Superadmin can read; no client writes permitted.
    match /auditLogs/{logId} {
      allow read:  if isSuperAdmin();
      allow write: if false;
    }

  }
}
